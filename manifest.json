{
  "manifest_version": 3,
  "version": "1.0.0",
  "name": "USD Converter for av.by",
  "description": "Converts prices on av.by to USD",
  "icons": {
    "16": "avby-usd-back16x16.png",
    "32": "avby-usd-back32x32.png",
    "48": "avby-usd-back48x48.png",
    "128": "avby-usd-back128x128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.av.by/*",
        "*://*.yandex.ru/adfox/*",
        "*://*.adfox.ru/*"
      ],
      "js": [
        "src/pages/content/index.tsx"
      ],
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://api.nbrb.by/*",
    "https://open.er-api.com/*",
    "https://api.frankfurter.dev/*"
  ]
}
