{
  "manifest_version": 3,
  "name": "AV.BY USD Converter",
  "description": "Converts prices on av.by to USD",
  "icons": {
    "128": "icon-128.png",
    "32": "icon-32.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.av.by/*"
      ],
      "js": [
        "src/pages/content/index.tsx"
      ]
    }
  ],
  "permissions": [
    "storage"
  ]
}
